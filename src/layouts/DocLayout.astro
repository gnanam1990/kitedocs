---
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import Sidebar from "../components/Sidebar.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  current?: string;
  preview?: boolean;
}

const { title, description, current, preview } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · KiteDocs</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body class="min-h-screen flex flex-col kite-shell">
    <SiteHeader current={current} />
    <main class="flex-1 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-10 grid lg:grid-cols-[17rem,1fr] gap-8 lg:gap-10 w-full">
      <aside class="hidden lg:block sticky top-24 self-start max-h-[calc(100vh-7rem)] overflow-y-auto rounded-xl border border-kite-border bg-kite-card/80 p-4 shadow-2xl shadow-black/10">
        <Sidebar current={current} />
      </aside>
      <section class="min-w-0">
        <details class="lg:hidden mb-6 rounded-xl border border-kite-border bg-kite-card/90 p-4">
          <summary class="cursor-pointer text-xs font-bold uppercase text-kite-primary">Browse docs</summary>
          <div class="mt-4">
            <Sidebar current={current} />
          </div>
        </details>
      <article class="prose max-w-3xl rounded-xl border border-kite-border bg-kite-card/85 p-5 sm:p-8 shadow-2xl shadow-black/10">
        {preview && (
          <span class="inline-flex items-center px-2 py-0.5 mb-4 text-[10px] font-bold uppercase rounded-sm bg-kite-primary/15 text-kite-primary border border-kite-primary/30">
            PREVIEW
          </span>
        )}
        <slot />
        </article>
      </section>
    </main>
    <SiteFooter />
  </body>
</html>
