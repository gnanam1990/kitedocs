---
import { getCollection } from "astro:content";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import "../../styles/global.css";

const collectionMeta = {
  tutorials: {
    heading: "Tutorials",
    eyebrow: "Learn by shipping",
    description: "Hands-on flows for accounts, payments, signing, and your first Kite transaction.",
  },
  reference: {
    heading: "Reference",
    eyebrow: "Copy-ready details",
    description: "RPC URLs, chain IDs, contract addresses, glossary entries, and common questions.",
  },
  guides: {
    heading: "Guides",
    eyebrow: "Integration playbooks",
    description: "Language and framework notes for wiring Kite into real applications.",
  },
} as const;

type CollectionKey = keyof typeof collectionMeta;

export async function getStaticPaths() {
  const collections = ["tutorials", "reference", "guides"] as const;
  return Promise.all(
    collections.map(async (collection) => ({
      params: { collection },
      props: {
        collection,
        entries: (await getCollection(collection)).sort((a, b) => a.data.order - b.data.order),
      },
    })),
  );
}

const { collection, entries } = Astro.props as {
  collection: CollectionKey;
  entries: Awaited<ReturnType<typeof getCollection>>;
};
const meta = collectionMeta[collection];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{meta.heading} · KiteDocs</title>
    <meta name="description" content={meta.description} />
  </head>
  <body class="min-h-screen flex flex-col">
    <SiteHeader current={collection} />

    <section style="background: linear-gradient(135deg, #FEF8F0 0%, #F1EBE0 50%, #E3D7C2 100%);" class="border-b border-kite-border">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
        <p class="text-xs font-bold tracking-widest uppercase text-kite-primary mb-3">{meta.eyebrow}</p>
        <h1 class="text-5xl sm:text-6xl font-bold tracking-tight text-kite-fg">{meta.heading}</h1>
        <p class="mt-5 text-lg text-kite-fg/70 max-w-2xl mx-auto">{meta.description}</p>
      </div>
    </section>

    <main class="flex-1 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-6 w-full">
      {entries.map((entry) => (
        <a href={`/${collection}/${entry.slug}`} class="block rounded-xl border border-kite-border bg-kite-card p-6 hover:border-kite-primary transition-colors">
          <div class="flex items-center justify-between gap-3">
            <span class="text-[10px] font-bold tracking-widest uppercase text-kite-primary">Doc {entry.data.order}</span>
            {entry.data.preview && (
              <span class="rounded-sm border border-kite-primary/30 px-2 py-0.5 text-[10px] font-bold tracking-widest uppercase text-kite-primary">Preview</span>
            )}
          </div>
          <h2 class="mt-4 text-xl font-bold tracking-tight text-kite-fg">{entry.data.title}</h2>
          <p class="mt-3 text-sm leading-relaxed text-kite-fg/65">{entry.data.description}</p>
          <span class="mt-5 inline-flex text-sm font-semibold text-kite-primary underline underline-offset-2">Open guide</span>
        </a>
      ))}
    </main>

    <SiteFooter />
  </body>
</html>
